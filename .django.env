# Django Production Environment Configuration
# Copy this to /home/ubuntu/.django.env on the deployment server

# ========== DJANGO CORE SETTINGS ==========
DEBUG=False
DJANGO_SETTINGS_MODULE=backend.settings

# SECURITY WARNING: Generate a new SECRET_KEY for production
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secure-random-secret-key-here-change-this

# Allowed hosts for CSRF protection (comma-separated)
ALLOWED_HOSTS=3.93.0.169,yourdomain.com,www.yourdomain.com

# ========== DATABASE CONFIGURATION ==========
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nepali_dating_db
DB_USER=postgres
DB_PASSWORD=your-secure-db-password-here
DB_HOST=localhost
DB_PORT=5432

# ========== SECURITY SETTINGS ==========
# Set to True in production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=True

# ========== LOGGING & MONITORING ==========
LOG_LEVEL=INFO

# ========== APPLICATION SETTINGS ==========
APP_NAME=nepali_dating_python
APP_PORT=7000
CONTAINER_PORT=8000

# ========== JWT SETTINGS (if using JWT authentication) ==========
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
